{
  "name": "landrop",
  "version": "1.2.4",
  "description": "Ultra-fast LAN file sharing — a modern DC++ replacement",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.landrop.app",
    "productName": "LANDrop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "lib/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico",
      "executableName": "LANDrop"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "LANDrop-Setup-${version}.${ext}",
      "shortcutName": "LANDrop",
      "include": "build/installer.nsh"
    }
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "electron-store": "^8.2.0",
    "express": "^4.21.0",
    "multer": "^2.0.2",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.3.0",
    "electron-builder": "^26.8.2"
  },
  "overrides": {
    "glob": "^11.0.0",
    "inflight": "npm:lru-cache@^10.0.0"
  }
}
